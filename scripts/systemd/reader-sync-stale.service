[Unit]
Description=Reader — background-sync the stalest feeds for all users
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
# Adjust the path if the repo lives elsewhere on the host.
ExecStart=/usr/bin/node /home/petter/github/reader/scripts/sync-stale.mjs
# Auth is read from ~/.config/reader/env (READER_CRON_KEY) —
# no EnvironmentFile needed.
Nice=10
