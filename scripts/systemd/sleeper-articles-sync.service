[Unit]
Description=Reader — sync the Sleeper Articles service into the Found feed
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
# Adjust the path if the repo lives elsewhere on the host.
ExecStart=/usr/bin/node /home/petter/github/reader/scripts/sleeper-articles-sync.mjs
# Secrets/state are read from ~/.config/sleeper-articles/ and ~/.config/reader/ —
# no EnvironmentFile needed.
Nice=10
