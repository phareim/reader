[Unit]
Description=Reader — sync Instapaper saves into the Found feed
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
# Adjust the path if the repo lives elsewhere on the host.
ExecStart=/usr/bin/node /home/petter/github/reader/scripts/instapaper-sync.mjs
# Secrets/state are read from ~/.config/instapaper/ and ~/.config/reader/ —
# no EnvironmentFile needed.
Nice=10
