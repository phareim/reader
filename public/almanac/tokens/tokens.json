{
  "$schema": "./tokens.schema.json",
  "name": "almanac",
  "version": "1.0.0",
  "source": "Lifted from ~/chat/frontend/SleeperChat/SleeperChat/Design/AlmanacTheme.swift @ 2026-05-10. iOS file is hand-maintained; if you change values here, update the iOS file by hand.",
  "palette": {
    "light": {
      "paper":  "#f4f0e8",
      "ink":    "#1a1a1a",
      "mute":   "#6a6a6a",
      "rust":   "#c14a2a",
      "rule":   "#d8d2c4"
    },
    "dark": {
      "nightTop":    "#161b24",
      "nightBottom": "#0e1219",
      "nightInk":    "#ebe4d4",
      "nightMute":   "#7a8a9a",
      "amber":       "#d4a574",
      "nightRule":   "rgba(255, 255, 255, 0.10)",
      "nightHeaderRule": "rgba(235, 228, 212, 0.18)"
    }
  },
  "type": {
    "serif": "\"Source Serif 4\", Georgia, \"Iowan Old Style\", Charter, serif",
    "mono":  "\"SF Mono\", ui-monospace, Menlo, Consolas, monospace",
    "sizes": {
      "headline": 26,
      "body":     14,
      "italic":   13,
      "monoLabel": 9
    },
    "lineHeight": {
      "headline": 1.2,
      "body":     1.55
    },
    "tracking": {
      "monoLabel": "0.16em",
      "headline": "-0.012em"
    },
    "measureCh": 65
  },
  "space": {
    "gutter":     22,
    "sectionGap": 14,
    "hairline":    1
  },
  "motion": {
    "cursorBlinkHz": 1
  },
  "glow": {
    "amber": {
      "color": "rgba(212, 165, 116, 0.25)",
      "radius": 4,
      "applies": ["MonoLabel", "OrbitalGlyph dot"],
      "scheme": "dark"
    }
  },
  "glyph": {
    "orbital": {
      "size": 38,
      "circleStrokeOpacity": { "light": 1.0, "dark": 0.4 },
      "capsuleWidthRatio":   1.42,
      "capsuleHeightRatio":  0.36,
      "capsuleRotation":   -25,
      "dotSize": 4
    }
  },
  "starfield": {
    "scheme": "dark",
    "starCount": 6,
    "starSize": 1.4,
    "stars": [
      [0.12, 0.22, 0.55],
      [0.88, 0.14, 0.35],
      [0.30, 0.88, 0.45],
      [0.70, 0.60, 0.25],
      [0.45, 0.42, 0.40],
      [0.62, 0.78, 0.30]
    ],
    "starsNote": "Each entry is [x, y, opacity] in 0..1 normalized coordinates; opacity is white-on-night."
  }
}
