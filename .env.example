# Feed parser configuration
FETCH_TIMEOUT=30000
MAX_ARTICLES_PER_FEED=200

# SFL elevate (swipe-up sends articles into the SFL idea tracker)
NUXT_SFL_API_URL="https://sfl-api.aiwdm.workers.dev"
NUXT_SFL_API_KEY="..."

# Read-aloud (the "Listen" button proxies to the reader-tts service on Sleeper)
NUXT_TTS_API_URL="https://sleeper.phareim.no/reader-tts"
NUXT_TTS_API_KEY="..."

# Sign-up gate: required invite code (sign-up is closed while unset)
NUXT_INVITE_CODE="..."

# Personal integrations (SFL elevate, highlight mirror, read-aloud) — comma list
NUXT_PERSONAL_EMAILS="you@example.com"

# Background sync: Bearer key for POST /api/internal/sync-{stale,x-bookmarks}
NUXT_CRON_KEY="..."

# Link-your-X-account (Sources page) + Worker-side bookmark sync.
# The redirect URI https://<host>/api/auth/x/callback must be registered
# on the X app. Fails soft (button hidden) while unset.
NUXT_X_CLIENT_ID="..."
NUXT_X_CLIENT_SECRET="..."
